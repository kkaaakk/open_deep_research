OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
LANGSMITH_TRACING=

# Only necessary for Open Agent Platform
SUPABASE_KEY=
SUPABASE_URL=
# Should be set to true for a production deployment on Open Agent Platform. Should be set to false otherwise, such as for local development.
GET_API_KEYS_FROM_CONFIG=false

# Optional local RAG configuration
RAG_ENABLED=true
RETRIEVAL_MODE=hybrid
RAG_KNOWLEDGE_BASE_PATHS=data/knowledge/public_opinion
RAG_MEMORY_ENABLED=true
RAG_MEMORY_PATHS=data/memory/public_opinion/memories.jsonl
RAG_MEMORY_JSON_TEXT_FIELDS=content
RAG_TOP_K=4
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200
RAG_RERANK_TOP_N=6
RAG_EMBEDDING_PROVIDER=hash
RAG_VECTORSTORE_PROVIDER=memory
RAG_RERANKER_PROVIDER=simple
RAG_GRAPH_ENABLED=true
RAG_GRAPH_BACKEND=neo4j
RAG_GRAPH_MAX_NEIGHBORS=4
RAG_GRAPH_WEIGHT=0.35
RAG_NEO4J_URI=bolt://localhost:7687
RAG_NEO4J_USERNAME=neo4j
RAG_NEO4J_PASSWORD=
RAG_NEO4J_DATABASE=
RAG_JSON_TEXT_FIELDS=

# Optional social media skill / low-level MCP adapter
SOCIAL_MEDIA_MCP_TRANSPORT=streamable-http
SOCIAL_MEDIA_MCP_HOST=127.0.0.1
SOCIAL_MEDIA_MCP_PORT=8001
SOCIAL_MEDIA_DATA_PATHS=data/social_media/bulk_mock_posts.jsonl,data/social_media/sample_posts.jsonl
SOCIAL_MEDIA_WRITE_PATH=data/social_media/saved_posts.jsonl
SOCIAL_MEDIA_API_BASE_URL=
SOCIAL_MEDIA_API_KEY=
SOCIAL_MEDIA_API_TIMEOUT=180
SOCIAL_MEDIA_NEGATIVE_QUERY_VARIANTS=4
SOCIAL_MEDIA_ENTITY_ALIASES=
SOCIAL_MEDIA_RISK_RULES=

# Optional Apify adapter for real social/public-opinion data.
# Start with: python -m open_deep_research.social_media_apify_api --host 127.0.0.1 --port 9000
# Then set SOCIAL_MEDIA_API_BASE_URL=http://127.0.0.1:9000
APIFY_TOKEN=
APIFY_SOCIAL_API_HOST=127.0.0.1
APIFY_SOCIAL_API_PORT=9000
APIFY_SOCIAL_RUN_TIMEOUT=120
# JSON object mapping platform names to Apify Actor configs.
# Example:
# APIFY_SOCIAL_ACTORS={"x":{"actor_id":"apidojo/tweet-scraper","input":{"searchTerms":["{query}"],"maxItems":"{limit}"}}}
APIFY_SOCIAL_ACTORS=
APIFY_SOCIAL_CACHE_PATH=data/social_media/apify_cache.jsonl

# Bytebase DBHub MCP — database query tools (requires Node.js >= 22.5.0)
DBHUB_ENABLED=false
DBHUB_DSN=mysql://dbhub_readonly:password@localhost:3306/mydb
DBHUB_TRANSPORT=stdio
DBHUB_HTTP_PORT=8080

# Microsoft MarkItDown MCP — convert files to Markdown (official microsoft/markitdown)
MARKITDOWN_ENABLED=false

# Feishu/Lark Official MCP — 飞书/Lark API tools
FEISHU_ENABLED=false
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=
FEISHU_DOMAIN=https://open.feishu.cn
FEISHU_MCP_PRESET=preset.light
FEISHU_OAUTH_ENABLED=false
